# LLM Provider 选择: 'claude' | 'aliyun' | 'bytedance' | 'openai'
LLM_PROVIDER=claude

# Claude API Key (provider=claude)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 阿里通义 API Key (provider=aliyun)
ALIYUN_API_KEY=sk-xxxxx

# 字节豆包 API Key (provider=bytedance)
BYTEDANCE_API_KEY=xxxxx

# OpenAI 兼容接口 (provider=openai)
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.openai.com/v1  # 默认值，可自定义
